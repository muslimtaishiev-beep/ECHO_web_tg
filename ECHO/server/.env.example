# ─── Database (PostgreSQL) ───
DATABASE_URL="postgresql://user:password@localhost:5432/echo_db?schema=public"

# ─── Security ───
JWT_SECRET="your-secure-jwt-secret-here"
ENCRYPTION_MASTER_KEY="64-char-hex-string-for-aes-256-encryption"

# ─── Server ───
PORT=3001
NODE_ENV=development

# ─── CORS (comma-separated origins) ───
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
